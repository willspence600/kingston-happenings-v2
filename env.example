# Copy this file to `.env` (for Prisma CLI) and/or `.env.local` (for Next.js).
# Do NOT commit your real secrets; `.gitignore` already ignores `.env*`.

# Supabase Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase API key for browser usage (Settings → API → Publishable key)
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Supabase API key for server-side admin operations (Settings → API → Secret key)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxx"

# Prisma runtime database connection (use Transaction Pooler / port 6543)
DATABASE_URL="postgres://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrations connection (use direct/session connection / port 5432)
DIRECT_URL="postgres://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

